# ============================================================
# SNHRC Asset Management System - Environment Configuration
# ============================================================
# Copy this file to .env and update the values

# Application
APP_NAME="SNHRC Asset Management"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000

# Database (PostgreSQL)
DB_DRIVER=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=snhrc
DB_USERNAME=postgres
DB_PASSWORD=YOUR_PASSWORD_HERE

# JWT Authentication
JWT_SECRET=snhrc-asset-mgmt-jwt-secret-2024-change-in-production
JWT_EXPIRY=3600

# CORS (add your frontend URL here)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:8082,http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log
